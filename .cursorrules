## app/globals.css

@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&family=Raleway:wght@400;500;600&display=swap');
@tailwind base;
@tailwind components;
@tailwind utilities;

---

## Color Role Map — use these Tailwind classes

### Navbar
- bg-white shadow-navbar
- Links: text-dark hover:text-primary
- CTA button: bg-btn-primary text-white shadow-btn hover:shadow-btn-hover rounded-btn

### Hero
- bg-hero (gradient)
- Heading: text-dark font-heading
- Highlight word: text-primary font-bold
- Italic phrase "Done For You": text-accent italic
- Subtext: text-muted font-body

### Buttons
- Primary: bg-btn-primary text-white shadow-btn hover:shadow-btn-hover rounded-btn px-6 py-3
- Secondary: bg-white border-2 border-secondary text-secondary rounded-btn px-6 py-3

### Badge / Pill
- bg-primary/10 border border-primary/20 text-primary rounded-badge px-3 py-1 text-sm

### Stats Row
- Applications: bg-bg-blue  — number: text-primary
- Success Rate: bg-bg-green — number: text-secondary
- Turnaround:   bg-bg-copper — number: text-accent
- Rating:       bg-bg-blue  — number: text-primary

### Cards
- OCI:       bg-bg-green  border border-green-tint  rounded-card shadow-card  title: text-secondary
- e-Visa:    bg-bg-blue   border border-blue-tint   rounded-card shadow-card  title: text-primary
- Doc Audit: bg-bg-copper border border-copper-tint rounded-card shadow-card  title: text-accent
- Body text on all cards: text-muted

### Sections
- Odd sections:  bg-white
- Even sections: bg-bg-page

### Footer
- bg-dark border-t-[3px] border-primary
- Logo "Fly": text-secondary | Logo "OCI": text-primary
- Links: text-white/55 hover:text-white
- Badge: bg-secondary/15 text-secondary rounded-badge px-3 py-1

---

## Component Pattern (TypeScript example)

// components/PrimaryButton.tsx
interface PrimaryButtonProps {
  label: string
  onClick?: () => void
}

export default function PrimaryButton({ label, onClick }: PrimaryButtonProps) {
  return (
    <button
      onClick={onClick}
      className="bg-btn-primary text-white font-heading font-semibold
                 rounded-btn px-6 py-3 shadow-btn
                 hover:shadow-btn-hover transition-shadow duration-200"
    >
      {label}
    </button>
  )
}
